# shellcheck shell=bash

CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Required inputs. By default the example looks for the files below.
PROTEIN_PDB="${CONFIG_DIR}/inputs/target_protein.pdb"
LIGAND_FILE="${CONFIG_DIR}/inputs/target_ligand.mol2"

# Optional: use an existing fragment SDF instead of generating fragments.
# PREMD_FRAGMENTS="${CONFIG_DIR}/inputs/target_fragments.sdf"

# Main output location.
WORK_ROOT="${CONFIG_DIR}/runs"
PREFIX="target"

# Stage control.
START_STAGE="premd"
STOP_AFTER="usmd"

# MD settings.
MD_TIME_NS="5"
NUM_LIGANDS=""
GPUID="0"
RESID=""
SSBOND=""
MD_PREPARE_ONLY="0"

# SMD settings.
LIGANDS_CSV=""
REPLICAS="1"
SMD_SUFFIX_PATTERN="exit_smd_rep{rep}"
SMD_RK2="5.0"
GENERATE_CV="1"
CV_FILE=""

# USMD + WHAM settings.
US_EXTRACT_START="0"
US_EXTRACT_END="30"
US_EXTRACT_STEP="0.5"
US_TOLERANCES="0.2,0.1,0.05,0.01"
US_WINDOW_START="25.0"
US_WINDOW_END="1.0"
US_WINDOW_STEP="-1.0"
WHAM_META_STEP="-3.0"
WHAM_MIN="0"
WHAM_MAX="25"
WHAM_BINS="260"
WHAM_TEMP="300"
WHAM_FORCE="10.0"

# Optional environment helpers. Uncomment and edit only if needed.
# DCBK_AMBER_SH="/path/to/amber.sh"
# DCBK_CONDA_SH="/path/to/conda.sh"
# DCBK_CONDA_ENV="dcbk_env"
# DCBK_PYTHON="python3"
# DCBK_MD_ENGINE="pmemd.cuda"
